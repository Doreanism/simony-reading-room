{
  "name": "simony-reading-room",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "npm run build:nuxt",
    "build:nuxt": "nuxt build && rm -rf .output/public/d .output/public/a .output/public/pagefind",
    "build:search-index": "tsx scripts/build-search-index.ts",
    "build:images": ".venv/bin/python3 scripts/build-page-images.py",
    "build:normalize-spreads": "tsx scripts/normalize-spread-sizes.ts",
    "build:page-json": ".venv/bin/python3 scripts/build-page-json.py",
    "build:merge": "tsx scripts/merge-transcriptions.ts",
    "build:readings": "tsx scripts/build-readings.ts",
    "generate": "npm run build && nuxt generate",
    "preview": "nuxt preview",
    "test": "vitest",
    "upload": "tsx scripts/upload-to-s3.ts",
    "download": "tsx scripts/download-from-s3.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@iconify-json/lucide": "^1.2.101",
    "@nuxt/test-utils": "^4.0.0",
    "better-sqlite3": "^12.8.0",
    "image-size": "^2.0.2",
    "pagefind": "^1.4.0",
    "playwright": "^1.58.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@nuxt/content": "^3.12.0",
    "@nuxt/ui": "^4.6.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "dotenv": "^17.3.1",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2"
  }
}
