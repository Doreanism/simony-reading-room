{
  "name": "simony-reading-room",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "npm run build:images && npm run build:normalize-spreads && npm run build:readings && nuxt build",
    "pipeline": "tsx scripts/pipeline.ts",
    "build:images": "tsx scripts/build-page-images.ts",
    "build:normalize-spreads": "tsx scripts/normalize-spread-sizes.ts",
    "build:page-json": "tsx scripts/build-page-json.ts",
    "build:merge": "tsx scripts/merge-transcriptions.ts",
    "build:transcriptions": "tsx scripts/generate-transcriptions.ts",
    "build:readings": "tsx scripts/build-readings.ts",
    "generate": "npm run build && nuxt generate",
    "preview": "nuxt preview",
    "test": "vitest",
    "upload": "tsx scripts/upload-to-s3.ts",
    "download": "tsx scripts/download-from-s3.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@nuxt/test-utils": "^4.0.0",
    "better-sqlite3": "^12.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@nuxt/content": "^3.12.0",
    "@nuxt/ui": "^4.6.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "dotenv": "^17.3.1",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2"
  }
}
